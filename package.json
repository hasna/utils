{
  "name": "@hasna/agent-utils",
  "version": "0.1.1",
  "description": "Shared utilities for token-efficient AI agent MCP servers and CLIs",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist/",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target bun && tsc --emitDeclarationOnly --outDir dist",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run build",
    "postinstall": "mkdir -p $HOME/.hasna/utils 2>/dev/null || true"
  },
  "keywords": ["mcp", "agent", "utils", "token-optimization", "compact"],
  "author": "hasna",
  "license": "Apache-2.0",
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hasna/utils.git"
  },
  "bugs": {
    "url": "https://github.com/hasna/utils/issues"
  },
  "homepage": "https://github.com/hasna/utils#readme",
  "devDependencies": {
    "@types/bun": "^1.2.4",
    "typescript": "^5.7.3"
  },
  "dependencies": {
    "@hasna/cloud": "^0.1.24"
  }
}
